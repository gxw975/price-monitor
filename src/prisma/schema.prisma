generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int       @id @default(autoincrement())
  username   String    @unique
  password   String
  role       String    @default("staff")
  created_at DateTime  @default(now()) @map("createdAt")
  keywords   Keyword[]
}

model Product {
  product_id           String    @id
  title                String
  main_image_url       String?
  shop_name            String
  shop_type            String?
  shipping_area        String?
  is_approved          Boolean   @default(false)
  is_whitelist         Boolean   @default(false)
  created_at           DateTime  @default(now())
  last_updated_at      DateTime  @default(now())
  last_sku_crawled_at  DateTime?

  histories        ProductHistory[]
  skus             ProductSku[]
  productKeywords  ProductKeyword[]
}

model ProductHistory {
  id           Int      @id @default(autoincrement())
  product_id   String
  price        Decimal  @db.Decimal(10, 2)
  sales_volume Int
  recorded_at  DateTime @default(now())

  product Product @relation(fields: [product_id], references: [product_id])

  @@index([product_id, recorded_at])
}

model ProductSku {
  id            Int      @id @default(autoincrement())
  product_id    String
  sku_name      String
  sku_price     Decimal  @db.Decimal(10, 2)
  unit_price    Decimal  @db.Decimal(10, 2)
  sku_image_url String?
  recorded_at   DateTime @default(now())

  product Product @relation(fields: [product_id], references: [product_id])

  @@index([product_id])
}

model SystemConfig {
  id                     Int       @id @default(autoincrement())
  alert_price            Decimal   @db.Decimal(10, 2)
  work_start_hour        Int       @default(9)
  work_end_hour          Int       @default(18)
  sales_growth_threshold Int       @default(100)
  alert_dedup_hours      Int       @default(24)
  crawl_schedule_type    String    @default("interval")
  crawl_fixed_times      String?
  crawl_daily_limit      Int       @default(100)
  check_alert_interval   Int       @default(180)
  created_at             DateTime  @default(now())
  updated_at             DateTime  @default(now())
  keywords               String    @default("[]")
  sku_crawl_limit        Int       @default(10)
  sku_crawl_interval     Int       @default(120)
}

model Alert {
  id         Int       @id @default(autoincrement())
  product_id String
  alert_type String
  message    String
  is_sent    Boolean   @default(false)
  sent_at    DateTime?
  is_read    Boolean   @default(false)
  created_at DateTime  @default(now())

  @@index([product_id, created_at])
  @@index([alert_type, created_at])
  @@index([is_read, created_at])
}

model Keyword {
  id         Int      @id @default(autoincrement())
  name       String
  platform   String   @default("taobao")
  is_active  Boolean  @default(true)
  created_by Int
  created_at DateTime @default(now()) @map("createdAt")

  creator         User            @relation(fields: [created_by], references: [id])
  productKeywords ProductKeyword[]

  @@index([is_active, created_at])
}

model ProductKeyword {
  keyword_id Int
  product_id String
  keyword    Keyword @relation(fields: [keyword_id], references: [id])
  product    Product @relation(fields: [product_id], references: [product_id])

  @@id([keyword_id, product_id])
  @@index([product_id])
  @@index([keyword_id])
}
